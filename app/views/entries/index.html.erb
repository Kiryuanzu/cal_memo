<%
  button_base_classes = "inline-flex min-h-11 items-center justify-center rounded-full px-4 text-sm font-semibold transition duration-200 hover:-translate-y-0.5"
  primary_button_classes = "#{button_base_classes} bg-gradient-to-br from-orange-500 to-orange-700 text-orange-50 shadow-[0_12px_24px_rgba(154,52,18,0.22)] hover:from-orange-400 hover:to-orange-600"
  subtle_button_classes = "#{button_base_classes} border border-stone-200/80 bg-white/80 text-stone-700 shadow-sm shadow-stone-950/5 hover:border-orange-200 hover:bg-orange-50"
  danger_button_classes = "#{button_base_classes} bg-rose-600 text-rose-50 shadow-[0_12px_24px_rgba(159,18,57,0.18)] hover:bg-rose-500"
%>

<% content_for :title, "カロリー計算メモ帳" %>

<main class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-4 py-10 sm:px-6 lg:px-8">
  <section class="relative overflow-hidden rounded-[32px] border border-stone-200/80 bg-gradient-to-br from-white/90 via-orange-50/90 to-rose-50/80 p-8 shadow-[0_18px_50px_rgba(54,31,18,0.12)] backdrop-blur-xl md:p-10">
    <div class="absolute -right-6 -top-10 h-36 w-36 rounded-full bg-rose-200/40 blur-2xl"></div>
    <div class="absolute -bottom-12 -left-4 h-44 w-44 rounded-full bg-amber-100/70 blur-2xl"></div>

    <div class="relative z-10 flex flex-col gap-6 xl:flex-row xl:items-center xl:justify-between">
      <div class="max-w-2xl">
        <p class="inline-flex rounded-full border border-orange-200/70 bg-white/80 px-4 py-2 text-sm font-semibold text-orange-900 shadow-sm shadow-orange-950/5">
          きょうのごはんメモ
        </p>
        <p class="mt-4 text-[0.78rem] font-bold tracking-[0.22em] text-stone-500">CALORIE MEMO BOOK</p>
        <h1 class="mt-3 max-w-[10ch] font-serif text-4xl leading-none tracking-tight text-stone-950 sm:text-5xl lg:text-6xl">
          カロリー計算メモ帳
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-stone-600">食べたものを、あとから見返しやすく。毎日の記録をふんわり残せます。</p>
      </div>

      <div class="grid gap-4 xl:justify-items-end">
        <div class="min-w-[220px] rounded-[24px] border border-stone-200/80 bg-white/80 px-5 py-4 text-left shadow-sm shadow-stone-950/5 xl:text-right">
          <p class="text-sm text-stone-600"><%= @today.strftime("%Y/%m/%d") %> の合計</p>
          <p class="mt-2 text-2xl font-extrabold tracking-tight text-orange-900 sm:text-3xl"><strong><%= number_with_delimiter(@today_total_calories) %> kcal</strong></p>
        </div>

        <%= link_to "記録を追加", new_entry_path, class: primary_button_classes %>
      </div>
    </div>
  </section>

  <section class="rounded-[28px] border border-stone-200/80 bg-white/75 p-6 shadow-[0_18px_50px_rgba(54,31,18,0.12)] backdrop-blur-xl md:p-7">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-serif text-3xl leading-tight tracking-tight text-stone-950">記録一覧</h2>
        <p class="mt-2 text-sm leading-6 text-stone-600">日時の新しい順に表示しています。</p>
      </div>
      <p class="text-sm font-semibold text-stone-600"><%= @entries.count %>件</p>
    </div>

    <% if @entries.any? %>
      <div class="mt-6 grid gap-3">
        <% @entries.each do |entry| %>
          <article class="flex flex-col gap-4 rounded-[24px] border border-stone-200/80 bg-white/90 px-5 py-4 shadow-sm shadow-stone-950/5 lg:flex-row lg:items-center lg:justify-between">
            <div class="grid gap-3">
              <p class="text-sm font-bold text-orange-900"><%= entry.eaten_at.strftime("%m/%d %H:%M") %></p>
              <div>
                <h3 class="text-lg font-semibold text-stone-950"><%= entry.name %></h3>
                <% if entry.note.present? %>
                  <p class="mt-1 text-sm leading-6 text-stone-600"><%= entry.note %></p>
                <% end %>
              </div>
            </div>

            <div class="grid gap-3 lg:justify-items-end">
              <p class="text-lg font-extrabold tracking-tight text-stone-950"><%= number_with_delimiter(entry.calories) %> kcal</p>
              <div class="flex flex-wrap gap-2">
                <%= link_to "編集", edit_entry_path(entry), class: subtle_button_classes %>
                <%= button_to "削除", entry_path(entry), method: :delete, class: danger_button_classes, form: { data: { turbo_confirm: "この記録を削除しますか？" } } %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 rounded-[24px] border border-dashed border-stone-300/80 bg-white/60 px-5 py-8 text-center text-sm text-stone-600">
        まだ記録がありません。最初の1件を追加してください。
      </div>
    <% end %>
  </section>
</main>
