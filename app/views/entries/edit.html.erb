<% content_for :title, "記録を編集" %>

<main class="mx-auto w-full max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
  <section class="rounded-[28px] border border-stone-200/80 bg-white/80 p-6 shadow-[0_18px_50px_rgba(54,31,18,0.12)] backdrop-blur-xl md:p-8">
    <div class="mb-6">
      <p class="text-[0.78rem] font-bold tracking-[0.22em] text-stone-500">EDIT ENTRY</p>
      <h1 class="mt-3 font-serif text-4xl leading-none tracking-tight text-stone-950">記録を編集</h1>
      <p class="mt-3 text-sm leading-6 text-stone-600">必要な項目だけ直して保存します。</p>
    </div>

    <%= render "form", entry: @entry %>
  </section>
</main>
