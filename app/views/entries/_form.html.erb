<%
  label_classes = "text-sm font-semibold text-stone-700"
  input_classes = "mt-2 w-full rounded-2xl border border-stone-200/80 bg-white px-4 py-3 text-sm text-stone-900 shadow-inner shadow-stone-950/5 focus:border-orange-300 focus:outline-none focus:ring-4 focus:ring-orange-100"
  button_base_classes = "inline-flex min-h-11 items-center justify-center rounded-full px-4 text-sm font-semibold transition duration-200 hover:-translate-y-0.5"
  primary_button_classes = "#{button_base_classes} bg-gradient-to-br from-orange-500 to-orange-700 text-orange-50 shadow-[0_12px_24px_rgba(154,52,18,0.22)] hover:from-orange-400 hover:to-orange-600"
  subtle_button_classes = "#{button_base_classes} border border-stone-200/80 bg-white/80 text-stone-700 shadow-sm shadow-stone-950/5 hover:border-orange-200 hover:bg-orange-50"
%>

<%= form_with(model: entry, class: "space-y-5") do |form| %>
  <% if entry.errors.any? %>
    <div class="rounded-[24px] border border-rose-200/80 bg-rose-50/90 px-5 py-4 text-rose-900 shadow-[0_12px_30px_rgba(136,19,55,0.12)]">
      <h2 class="text-base font-semibold">入力内容を確認してください。</h2>

      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm">
        <% entry.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "食品名", class: label_classes %>
    <%= form.text_field :name, placeholder: "バナナ", autofocus: true, class: input_classes %>
  </div>

  <div>
    <%= form.label :calories, "カロリー", class: label_classes %>
    <%= form.number_field :calories, min: 1, step: 1, placeholder: "86", class: input_classes %>
  </div>

  <div>
    <%= form.label :eaten_at, "日時", class: label_classes %>
    <%= form.datetime_field :eaten_at, value: (entry.eaten_at || Time.zone.now).strftime("%Y-%m-%dT%H:%M"), class: input_classes %>
  </div>

  <div>
    <%= form.label :note, "メモ", class: label_classes %>
    <%= form.textarea :note, rows: 4, placeholder: "任意", class: "#{input_classes} min-h-32 resize-y" %>
  </div>

  <div class="flex flex-col gap-3 pt-3 sm:flex-row sm:justify-between">
    <%= link_to "キャンセル", entries_path, class: subtle_button_classes %>
    <%= form.submit entry.persisted? ? "更新する" : "登録する", class: primary_button_classes %>
  </div>
<% end %>
