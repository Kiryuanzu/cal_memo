<% if notice.present? %>
  <p class="mb-3 rounded-2xl border border-emerald-200/80 bg-emerald-50/90 px-4 py-3 text-sm font-medium text-emerald-900 shadow-[0_12px_30px_rgba(6,95,70,0.12)] backdrop-blur">
    <%= notice %>
  </p>
<% end %>
<% if alert.present? %>
  <p class="mb-3 rounded-2xl border border-rose-200/80 bg-rose-50/90 px-4 py-3 text-sm font-medium text-rose-900 shadow-[0_12px_30px_rgba(136,19,55,0.12)] backdrop-blur">
    <%= alert %>
  </p>
<% end %>
