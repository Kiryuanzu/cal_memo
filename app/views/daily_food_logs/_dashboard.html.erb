<main id="page-top" class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-4 pb-10 pt-32 sm:px-6 sm:pt-36 lg:px-8">
  <header class="fixed inset-x-0 top-0 z-40 border-b border-stone-200/80 bg-white/80 shadow-[0_14px_30px_rgba(54,31,18,0.08)] backdrop-blur-xl" data-controller="section-nav">
    <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8">
      <button type="button" class="inline-flex min-h-11 items-center rounded-full bg-white/85 px-4 text-left font-display text-sm tracking-[0.18em] text-stone-950 transition duration-200 hover:-translate-y-0.5 hover:bg-white" data-action="section-nav#scroll" data-section-nav-section-id-param="page-top">
        CALORIE MEMO BOOK
      </button>

      <nav class="flex flex-wrap gap-2" aria-label="画面内移動">
        <button type="button" class="<%= section_tab_classes %>" data-action="section-nav#scroll" data-section-nav-section-id-param="summary-section">集計</button>
        <button type="button" class="<%= section_tab_classes %>" data-action="section-nav#scroll" data-section-nav-section-id-param="input-section">入力</button>
        <button type="button" class="<%= section_tab_classes %>" data-action="section-nav#scroll" data-section-nav-section-id-param="share-section">AI共有</button>
      </nav>
    </div>
  </header>

  <section class="relative overflow-hidden rounded-[32px] border border-stone-200/80 bg-gradient-to-br from-white/90 via-orange-50/90 to-rose-50/80 p-8 shadow-[0_18px_50px_rgba(54,31,18,0.12)] backdrop-blur-xl md:p-10">
    <div class="absolute -right-6 -top-10 h-36 w-36 rounded-full bg-rose-200/40 blur-2xl"></div>
    <div class="absolute -bottom-12 -left-4 h-44 w-44 rounded-full bg-amber-100/70 blur-2xl"></div>

    <div class="relative z-10 flex flex-col gap-6">
      <div class="max-w-2xl">
        <p class="mt-4 font-display text-3xl leading-none tracking-[0.14em] text-stone-950 sm:text-4xl lg:text-5xl">CALORIE MEMO BOOK</p>
        <p class="mt-5 text-base font-semibold text-orange-900 sm:text-lg">
          <%= @selected_date.year %>年<%= @selected_date.month %>月<%= @selected_date.day %>日の記録
        </p>
      </div>

      <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(320px,0.85fr)] xl:items-stretch">
        <section class="grid gap-4 md:grid-cols-2">
          <div class="rounded-[28px] border px-5 py-5 shadow-[0_14px_30px_rgba(54,31,18,0.08)] shadow-stone-950/5 <%= calorie_tone_classes(@period_totals[:day]) %>">
            <p class="text-sm text-stone-600">今日の合計</p>
            <p class="mt-2 text-2xl font-extrabold tracking-tight sm:text-3xl">
              <strong><%= number_with_delimiter(@period_totals[:day]) %> kcal</strong>
              <span class="mx-1 text-stone-300">/</span>
              <span class="text-xl text-stone-500 sm:text-2xl"><%= number_with_delimiter(DashboardHelper::DAILY_TARGET) %> kcal</span>
            </p>
            <div class="mt-4 h-3 overflow-hidden rounded-full bg-stone-200/80">
              <div class="h-full rounded-full bg-gradient-to-r from-orange-400 via-orange-500 to-orange-700" style="width: <%= progress_percent(@period_totals[:day], DashboardHelper::DAILY_TARGET) %>%"></div>
            </div>
            <p class="mt-3 text-sm leading-6 text-stone-500">合計カロリー上限の目安: <%= number_with_delimiter(DashboardHelper::DAILY_TARGET) %> kcal</p>
            <p class="mt-1 text-sm leading-6 text-stone-500">
              タンパク質: <strong class="text-stone-800"><%= @protein_summary[:day_total] %> g</strong>
              <span class="text-stone-300">/</span>
              <span><%= @protein_summary[:daily_target] %> g</span>
            </p>
          </div>
          <div class="rounded-[28px] border border-stone-200/80 bg-white/85 px-5 py-5 shadow-[0_14px_30px_rgba(54,31,18,0.08)] shadow-stone-950/5">
            <p class="text-sm text-stone-600">今週の合計</p>
            <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950 sm:text-3xl">
              <strong><%= number_with_delimiter(@period_totals[:week]) %> kcal</strong>
              <span class="mx-1 text-stone-300">/</span>
              <span class="text-xl text-stone-500 sm:text-2xl"><%= number_with_delimiter(DashboardHelper::WEEKLY_TARGET_LOWER) %> kcal</span>
            </p>
            <div class="mt-4 h-3 overflow-hidden rounded-full bg-stone-200/80">
              <div class="h-full rounded-full bg-gradient-to-r from-orange-400 via-orange-500 to-orange-700" style="width: <%= progress_percent(@period_totals[:week], DashboardHelper::WEEKLY_TARGET_LOWER) %>%"></div>
            </div>
            <p class="mt-3 text-sm leading-6 text-stone-500">週の総摂取カロリー目安: 約<%= number_with_delimiter(DashboardHelper::WEEKLY_TARGET_LOWER) %>〜<%= number_with_delimiter(DashboardHelper::WEEKLY_TARGET_UPPER) %> kcal</p>
          </div>
        </section>
        <div class="grid gap-4">
          <div class="rounded-[28px] border border-stone-200/80 bg-white/85 px-5 py-5 shadow-[0_14px_30px_rgba(54,31,18,0.08)] shadow-stone-950/5">
            <p class="text-sm text-stone-600">今週の平均</p>
            <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950 sm:text-3xl">
              <strong><%= number_with_delimiter(@period_totals[:week_average]) %> kcal</strong>
              <span class="ml-2 text-base font-semibold text-stone-500 sm:text-lg">/ 日</span>
            </p>
          </div>
          <div class="rounded-[28px] border border-stone-200/80 bg-white/85 px-5 py-5 shadow-[0_14px_30px_rgba(54,31,18,0.08)] shadow-stone-950/5">
            <p class="text-sm text-stone-600">月の合計</p>
            <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950 sm:text-3xl">
              <strong><%= number_with_delimiter(@period_totals[:month]) %> kcal</strong>
              <span class="mx-1 text-stone-300">/</span>
              <span class="text-xl text-stone-500 sm:text-2xl"><%= number_with_delimiter(DashboardHelper::MONTHLY_TARGET) %> kcal</span>
            </p>
            <div class="mt-4 h-3 overflow-hidden rounded-full bg-stone-200/80">
              <div class="h-full rounded-full bg-gradient-to-r from-orange-400 via-orange-500 to-orange-700" style="width: <%= progress_percent(@period_totals[:month], DashboardHelper::MONTHLY_TARGET) %>%"></div>
            </div>
            <p class="mt-3 text-sm leading-6 text-stone-500">月の合計カロリー上限: <%= number_with_delimiter(DashboardHelper::MONTHLY_TARGET) %> kcal</p>
          </div>

          <div class="grid gap-2 sm:grid-cols-3 xl:grid-cols-1">
            <%= link_to "前の日", root_path(date: (@selected_date - 1.day).iso8601, tab: @selected_tab), class: subtle_button_classes %>
            <%= link_to "今日", root_path(tab: @selected_tab), class: primary_button_classes %>
            <%= link_to "次の日", root_path(date: (@selected_date + 1.day).iso8601, tab: @selected_tab), class: subtle_button_classes %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="summary-section" class="<%= panel_classes %> scroll-mt-28">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-serif text-3xl leading-tight tracking-tight text-stone-950">集計</h2>
        <p class="mt-2 text-sm leading-6 text-stone-600">日 / 週 / 月の切り替えで、最近の総摂取カロリーを確認できます。</p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <article class="rounded-[24px] border p-5 shadow-sm shadow-stone-950/5 <%= calorie_tone_classes(@period_totals[:day]) %>">
        <p class="text-sm text-stone-600">1日</p>
        <p class="mt-2 text-2xl font-extrabold tracking-tight">
          <strong><%= number_with_delimiter(@period_totals[:day]) %> kcal</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= number_with_delimiter(DashboardHelper::DAILY_TARGET) %> kcal</span>
        </p>
      </article>
      <article class="rounded-[24px] border border-stone-200/80 bg-white/85 p-5 shadow-sm shadow-stone-950/5">
        <p class="text-sm text-stone-600">週</p>
        <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950">
          <strong><%= number_with_delimiter(@period_totals[:week]) %> kcal</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= number_with_delimiter(DashboardHelper::WEEKLY_TARGET_LOWER) %> kcal</span>
        </p>
      </article>
      <article class="rounded-[24px] border border-stone-200/80 bg-white/85 p-5 shadow-sm shadow-stone-950/5">
        <p class="text-sm text-stone-600">月</p>
        <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950">
          <strong><%= number_with_delimiter(@period_totals[:month]) %> kcal</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= number_with_delimiter(DashboardHelper::MONTHLY_TARGET) %> kcal</span>
        </p>
      </article>
    </div>

    <nav class="mt-6 grid grid-cols-2 gap-2 sm:grid-cols-4" aria-label="集計切り替え">
      <% { "day" => "日", "week" => "週(合計)", "week_average" => "週(平均)", "month" => "月" }.each do |key, label| %>
        <% tab_classes = @selected_tab == key ? "inline-flex min-h-12 items-center justify-center rounded-full bg-gradient-to-br from-orange-500 to-orange-700 px-4 text-sm font-semibold text-orange-50 shadow-[0_12px_24px_rgba(154,52,18,0.22)]" : "inline-flex min-h-12 items-center justify-center rounded-full border border-stone-200/80 bg-white/85 px-4 text-sm font-semibold text-stone-700 shadow-sm shadow-stone-950/5 transition duration-200 hover:-translate-y-0.5 hover:border-orange-200 hover:bg-orange-50" %>
        <%= link_to label, root_path(date: @selected_date.iso8601, tab: key), class: tab_classes %>
      <% end %>
    </nav>

    <% if @selected_tab == "day" %>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm font-semibold text-stone-700">
          <%= @selected_date.beginning_of_week.month %>/<%= @selected_date.beginning_of_week.day %> - <%= @selected_date.end_of_week.month %>/<%= @selected_date.end_of_week.day %> の週
        </p>
        <div class="grid grid-cols-2 gap-2 sm:flex sm:gap-2">
          <%= link_to "前の週", root_path(date: (@selected_date - 7.days).iso8601, tab: @selected_tab), class: subtle_button_classes %>
          <%= link_to "次の週", root_path(date: (@selected_date + 7.days).iso8601, tab: @selected_tab), class: subtle_button_classes %>
        </div>
      </div>

      <p class="mt-3 text-xs text-stone-500">
        この週の1日平均: <strong class="text-sm font-semibold text-stone-800"><%= number_with_delimiter(@period_totals[:week_average]) %> kcal</strong>
      </p>
    <% end %>

    <% if @selected_tab.in?(%w[week week_average]) %>
      <article class="mt-6 rounded-[24px] border border-stone-200/80 bg-white/85 p-5 shadow-sm shadow-stone-950/5">
        <p class="text-sm text-stone-600">今週のタンパク質</p>
        <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950">
          <strong><%= @protein_summary[:week_total] %> g</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= @protein_summary[:week_target] %> g</span>
        </p>
        <p class="mt-2 text-sm text-stone-500">1日平均: <%= @protein_summary[:week_average] %> g（目標 <%= @protein_summary[:daily_target] %> g/日）</p>
        <p class="text-sm text-stone-500">
          <% if @protein_summary[:deficit].positive? %>
            不足: <%= @protein_summary[:deficit] %> g
          <% else %>
            達成済み（+<%= -@protein_summary[:deficit] %> g）
          <% end %>
        </p>
      </article>
    <% end %>

    <div class="mt-6 grid gap-3">
      <% @summary_rows.each do |row| %>
        <article class="flex flex-col gap-3 rounded-[22px] border px-5 py-4 shadow-sm shadow-stone-950/5 sm:flex-row sm:items-center sm:justify-between <%= calorie_tone_classes(row[:calories]) %>">
          <div>
            <p class="font-semibold text-stone-950"><%= row[:label] %></p>
            <p class="text-sm text-stone-600"><%= row[:subtitle] %></p>
          </div>
          <div class="sm:text-right">
            <p class="text-lg font-extrabold tracking-tight"><%= number_with_delimiter(row[:calories]) %> kcal</p>
            <% if row[:protein_g] %>
              <p class="text-xs text-stone-500">タンパク質 <%= row[:protein_g] %> g</p>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <section id="input-section" class="grid gap-6 scroll-mt-28 lg:grid-cols-2">
    <% @meal_sections.each do |section| %>
      <% selected_manual_food = @daily_food_log&.food if @daily_food_log&.food&.manual_calories_enabled? %>
      <% manual_foods = section[:foods].select(&:manual_calories_enabled?) %>
      <% form_open = selected_manual_food.present? && @daily_food_log&.meal_type == section[:key] %>
      <% current_manual_food = form_open ? selected_manual_food : manual_foods.first %>
      <% current_manual_calories = form_open ? @daily_food_log.calories : nil %>
      <section id="meal-<%= section[:key] %>-section" class="scroll-mt-28 rounded-[28px] border p-6 shadow-[0_18px_50px_rgba(54,31,18,0.12)] backdrop-blur-xl md:p-7 <%= section_tone_classes(section[:total_calories]) %>">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="inline-flex rounded-full px-3 py-1 text-sm font-extrabold <%= meal_badge_classes(section[:key]) %>"><%= section[:label] %></p>
            <h2 class="mt-3 font-serif text-3xl leading-tight tracking-tight text-stone-950"><%= section[:label] %>に食べたもの</h2>
            <p class="mt-2 text-sm leading-6 text-stone-600">候補から選ぶだけで登録できます。</p>
          </div>
          <p class="text-lg font-extrabold tracking-tight text-stone-950"><%= number_with_delimiter(section[:total_calories]) %> kcal</p>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-3" data-controller="manual-calorie-form" data-manual-calorie-form-open-value="<%= form_open %>">
          <% section[:foods].each do |food| %>
            <% if food.manual_calories_enabled? %>
              <button type="button" class="<%= food_button_classes %>" data-action="manual-calorie-form#show" data-manual-calorie-form-food-id-param="<%= food.id %>" data-manual-calorie-form-food-name-param="<%= food.name %>" data-manual-calorie-form-food-calories-param="<%= food.calories %>">
                <%= food.name %>
              </button>
            <% else %>
              <%= button_to food.name, daily_food_logs_path(date: @selected_date.iso8601, tab: @selected_tab),
                params: { daily_food_log: { food_id: food.id, meal_type: section[:key], eaten_on: @selected_date.iso8601 } },
                class: food_button_classes %>
            <% end %>
          <% end %>

          <% if manual_foods.any? %>
            <%= form_with url: daily_food_logs_path(date: @selected_date.iso8601, tab: @selected_tab), method: :post, class: "hidden rounded-[22px] border border-orange-200/70 bg-orange-50/80 p-4 shadow-sm shadow-stone-950/5 sm:col-span-2 xl:col-span-3", data: { action: "turbo:submit-end->manual-calorie-form#submitEnd", manual_calorie_form_target: "form" } do |form| %>
              <%= form.hidden_field :food_id, name: "daily_food_log[food_id]", value: current_manual_food&.id, data: { manual_calorie_form_target: "foodIdInput" } %>
              <%= form.hidden_field :meal_type, name: "daily_food_log[meal_type]", value: section[:key] %>
              <%= form.hidden_field :eaten_on, name: "daily_food_log[eaten_on]", value: @selected_date.iso8601 %>

              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-orange-950" data-manual-calorie-form-target="foodName"><%= current_manual_food&.name %></p>
                  <p class="mt-1 text-xs leading-5 text-stone-600">カロリーを入力して登録します。</p>
                </div>
                <button type="button" class="text-xs font-semibold text-stone-500 transition hover:text-stone-700" data-action="manual-calorie-form#hide">閉じる</button>
              </div>

              <div class="mt-3">
                <%= form.label :calories, "カロリー", class: "mb-2 block text-sm font-semibold text-stone-700" %>
                <%= form.number_field :calories,
                  name: "daily_food_log[calories]",
                  min: 1,
                  step: 1,
                  value: current_manual_calories,
                  placeholder: current_manual_food&.calories.to_s,
                  class: input_classes,
                  data: { manual_calorie_form_target: "caloriesInput" } %>
              </div>

              <%= form.submit "登録する", class: "mt-3 w-full sm:w-auto #{primary_button_classes}" %>
            <% end %>
          <% end %>
        </div>

        <% if section[:logs].any? %>
          <div class="mt-5 grid gap-3">
            <% section[:logs].each do |log| %>
              <article class="rounded-[22px] border border-stone-200/80 bg-white/90 px-4 py-4 shadow-sm shadow-stone-950/5">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="font-semibold text-stone-950"><%= log.food_name %></p>
                    <% if log.comment.present? %>
                      <p class="mt-1 whitespace-pre-line text-sm text-stone-600"><%= log.comment %></p>
                    <% else %>
                      <p class="text-sm text-stone-500">登録済み</p>
                    <% end %>
                  </div>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                    <p class="text-base font-extrabold tracking-tight text-stone-950"><%= number_with_delimiter(log.calories) %> kcal</p>
                    <%= button_to "削除", daily_food_log_path(log, date: @selected_date.iso8601, tab: @selected_tab), method: :delete, class: danger_button_classes, form: { data: { turbo_confirm: "この記録を削除しますか？" } } %>
                  </div>
                </div>

                <% if log.food&.manual_calories_enabled? %>
                  <details class="mt-3">
                    <summary class="cursor-pointer text-xs text-stone-500 hover:text-stone-700">
                      <%= log.comment.present? ? "コメントを編集" : "コメントを追加" %>
                    </summary>
                    <%= form_with url: daily_food_log_path(log, date: @selected_date.iso8601, tab: @selected_tab), method: :patch, class: "mt-2" do |form| %>
                      <%= form.text_area :comment, name: "daily_food_log[comment]", value: log.comment, rows: 2, placeholder: "店名や状況などのメモ", class: input_classes %>
                      <div class="mt-2">
                        <%= form.submit "保存", class: "text-xs #{primary_button_classes}" %>
                      </div>
                    <% end %>
                  </details>
                <% end %>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="mt-5 rounded-[22px] border border-dashed border-stone-300/80 bg-white/60 px-5 py-8 text-center text-sm text-stone-600">
            まだ記録がありません。上のボタンから追加してください。
          </div>
        <% end %>
      </section>
    <% end %>
  </section>

  <section id="share-section" class="<%= panel_classes %> scroll-mt-28">
    <div>
      <h2 class="font-serif text-3xl leading-tight tracking-tight text-stone-950">AI共有用テキスト</h2>
      <p class="mt-2 text-sm leading-6 text-stone-600">食事内容を自然文でコピーできます。</p>
    </div>

    <div class="mt-6 grid gap-6">
      <div data-controller="copy">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <h3 class="font-semibold text-stone-900">その日分</h3>
          <button type="button" class="<%= primary_button_classes %>" data-action="copy#copy">コピー</button>
        </div>
        <textarea class="mt-3 min-h-36 w-full rounded-[22px] border border-stone-200/80 bg-white/90 px-4 py-4 text-sm leading-7 text-stone-700 shadow-inner shadow-stone-950/5 focus:border-orange-300 focus:outline-none focus:ring-4 focus:ring-orange-100" rows="5" readonly data-copy-target="source"><%= @daily_summary_text %></textarea>
        <p class="mt-3 text-sm text-stone-500" data-copy-target="status"></p>
      </div>

      <div data-controller="copy">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <h3 class="font-semibold text-stone-900">1週間分（<%= @selected_date.beginning_of_week.month %>/<%= @selected_date.beginning_of_week.day %> - <%= @selected_date.end_of_week.month %>/<%= @selected_date.end_of_week.day %>）</h3>
          <button type="button" class="<%= primary_button_classes %>" data-action="copy#copy">コピー</button>
        </div>
        <textarea class="mt-3 min-h-36 w-full rounded-[22px] border border-stone-200/80 bg-white/90 px-4 py-4 text-sm leading-7 text-stone-700 shadow-inner shadow-stone-950/5 focus:border-orange-300 focus:outline-none focus:ring-4 focus:ring-orange-100" rows="9" readonly data-copy-target="source"><%= @weekly_summary_text %></textarea>
        <p class="mt-3 text-sm text-stone-500" data-copy-target="status"></p>
      </div>
    </div>
  </section>
</main>
