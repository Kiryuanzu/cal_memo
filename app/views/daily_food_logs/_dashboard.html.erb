<main id="page-top" class="<%= page_shell_classes %>">
  <header class="<%= top_bar_classes %>" data-controller="section-nav">
    <div class="<%= top_bar_inner_classes %>">
      <button
        type="button"
        class="<%= brand_control_classes %>"
        data-action="section-nav#scroll"
        data-section-nav-section-id-param="page-top"
      >
        CALORIE MEMO BOOK
      </button>

      <nav class="<%= nav_group_classes %>" aria-label="画面内移動">
        <button
          type="button"
          class="<%= section_tab_classes %>"
          data-action="section-nav#scroll"
          data-section-nav-section-id-param="summary-section"
        >
          集計
        </button>

        <button
          type="button"
          class="<%= section_tab_classes %>"
          data-action="section-nav#scroll"
          data-section-nav-section-id-param="input-section"
        >
          入力
        </button>

        <button
          type="button"
          class="<%= section_tab_classes %>"
          data-action="section-nav#scroll"
          data-section-nav-section-id-param="share-section"
        >
          AI共有
        </button>

        <%= link_to "食品一覧", foods_path, class: section_tab_classes, data: { turbo_frame: "_top" } %>
        <%= link_to "バランス", balance_path, class: section_tab_classes, data: { turbo_frame: "_top" } %>
      </nav>
    </div>
  </header>

  <section class="<%= hero_panel_classes %>">
    <div class="absolute -right-6 -top-10 h-36 w-36 rounded-full bg-rose-200/40 blur-2xl"></div>
    <div class="absolute -bottom-12 -left-4 h-44 w-44 rounded-full bg-amber-100/70 blur-2xl"></div>

    <div class="relative z-10 flex flex-col gap-6">
      <div class="max-w-2xl">
        <p class="<%= hero_title_classes %>">CALORIE MEMO BOOK</p>

        <p class="mt-5 text-base font-semibold text-orange-900 sm:text-lg">
          <%= @selected_date.year %>年<%= @selected_date.month %>月<%= @selected_date.day %>日の記録
        </p>
      </div>

      <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(320px,0.85fr)] xl:items-stretch">
        <section class="grid gap-4 md:grid-cols-2">
          <div class="<%= large_metric_card_classes(calorie_tone_classes(@period_totals[:day])) %>">
            <p class="<%= metric_label_classes %>">今日の合計</p>

            <p class="<%= metric_value_classes(color: false) %>">
              <strong><%= number_with_delimiter(@period_totals[:day]) %> kcal</strong>
              <span class="mx-1 text-stone-300">/</span>

              <span class="text-xl text-stone-500 sm:text-2xl">
                <%= number_with_delimiter(DashboardHelper::DAILY_TARGET) %> kcal
              </span>
            </p>

            <div class="<%= progress_track_classes %>">
              <div
                class="<%= progress_bar_classes %>"
                style="width: <%= progress_percent(@period_totals[:day], DashboardHelper::DAILY_TARGET) %>%"
              ></div>
            </div>

            <p class="<%= supporting_text_classes %>">
              合計カロリー上限の目安: <%= number_with_delimiter(DashboardHelper::DAILY_TARGET) %> kcal
            </p>

            <p class="<%= supporting_text_classes(spacing: "mt-1") %>">
              タンパク質: <strong class="text-stone-800"><%= @protein_summary[:day_total] %> g</strong>
              <span class="text-stone-300">/</span> <span><%= @protein_summary[:daily_target] %> g</span>
            </p>
          </div>

          <div class="<%= large_metric_card_classes %>">
            <p class="<%= metric_label_classes %>">今週の合計</p>

            <p class="<%= metric_value_classes %>">
              <strong><%= number_with_delimiter(@period_totals[:week]) %> kcal</strong>
              <span class="mx-1 text-stone-300">/</span>

              <span class="text-xl text-stone-500 sm:text-2xl">
                <%= number_with_delimiter(DashboardHelper::WEEKLY_TARGET_LOWER) %> kcal
              </span>
            </p>

            <div class="<%= progress_track_classes %>">
              <div
                class="<%= progress_bar_classes %>"
                style="width: <%= progress_percent(@period_totals[:week], DashboardHelper::WEEKLY_TARGET_LOWER) %>%"
              ></div>
            </div>

            <p class="<%= supporting_text_classes %>"><%= weekly_target_range_text %></p>
          </div>
        </section>

        <div class="grid gap-4">
          <div class="<%= large_metric_card_classes %>">
            <p class="<%= metric_label_classes %>">今週の平均</p>

            <p class="<%= metric_value_classes %>">
              <strong><%= number_with_delimiter(@period_totals[:week_average]) %> kcal</strong>
              <span class="ml-2 text-base font-semibold text-stone-500 sm:text-lg">/ 日</span>
            </p>
          </div>

          <div class="<%= large_metric_card_classes %>">
            <p class="<%= metric_label_classes %>">月の合計</p>

            <p class="<%= metric_value_classes %>">
              <strong><%= number_with_delimiter(@period_totals[:month]) %> kcal</strong>
              <span class="mx-1 text-stone-300">/</span>

              <span class="text-xl text-stone-500 sm:text-2xl">
                <%= number_with_delimiter(DashboardHelper::MONTHLY_TARGET) %> kcal
              </span>
            </p>

            <div class="<%= progress_track_classes %>">
              <div
                class="<%= progress_bar_classes %>"
                style="width: <%= progress_percent(@period_totals[:month], DashboardHelper::MONTHLY_TARGET) %>%"
              ></div>
            </div>

            <p class="<%= supporting_text_classes %>">
              月の合計カロリー上限: <%= number_with_delimiter(DashboardHelper::MONTHLY_TARGET) %> kcal
            </p>
          </div>

          <div class="grid gap-2 sm:grid-cols-3 xl:grid-cols-1">
            <%= link_to "前の日", root_path(date: (@selected_date - 1.day).iso8601, tab: @selected_tab), class: subtle_button_classes %>
            <%= link_to "今日", root_path(tab: @selected_tab), class: primary_button_classes %>
            <%= link_to "次の日", root_path(date: (@selected_date + 1.day).iso8601, tab: @selected_tab), class: subtle_button_classes %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="summary-section" class="<%= panel_classes %> scroll-mt-28">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="<%= section_title_classes %>">集計</h2>
        <p class="<%= section_description_classes %>">日 / 週 / 月の切り替えで、最近の総摂取カロリーを確認できます。</p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <article class="<%= summary_metric_card_classes(calorie_tone_classes(@period_totals[:day])) %>">
        <p class="<%= metric_label_classes %>">1日</p>

        <p class="mt-2 text-2xl font-extrabold tracking-tight">
          <strong><%= number_with_delimiter(@period_totals[:day]) %> kcal</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= number_with_delimiter(DashboardHelper::DAILY_TARGET) %> kcal</span>
        </p>
      </article>

      <article class="<%= summary_metric_card_classes %>">
        <p class="<%= metric_label_classes %>">週</p>

        <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950">
          <strong><%= number_with_delimiter(@period_totals[:week]) %> kcal</strong>
          <span class="mx-1 text-stone-300">/</span>

          <span class="text-lg text-stone-500">
            <%= number_with_delimiter(DashboardHelper::WEEKLY_TARGET_LOWER) %> kcal
          </span>
        </p>
      </article>

      <article class="<%= summary_metric_card_classes %>">
        <p class="<%= metric_label_classes %>">月</p>

        <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950">
          <strong><%= number_with_delimiter(@period_totals[:month]) %> kcal</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= number_with_delimiter(DashboardHelper::MONTHLY_TARGET) %> kcal</span>
        </p>
      </article>
    </div>

    <nav class="mt-6 grid grid-cols-2 gap-2 sm:grid-cols-4" aria-label="集計切り替え">
      <% { "day" => "日", "week" => "週(合計)", "week_average" => "週(平均)", "month" => "月" }.each do |key, label| %>
        <%= link_to label, root_path(date: @selected_date.iso8601, tab: key), class: period_tab_classes(@selected_tab == key) %>
      <% end %>
    </nav>

    <% if @selected_tab == "day" %>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm font-semibold text-stone-700">
          <%= @selected_date.beginning_of_week.strftime("%-m/%-d") %> -
          <%= @selected_date.end_of_week.strftime("%-m/%-d") %> の週
        </p>

        <div class="grid grid-cols-2 gap-2 sm:flex sm:gap-2">
          <%= link_to "前の週", root_path(date: (@selected_date - 7.days).iso8601, tab: @selected_tab), class: subtle_button_classes %>
          <%= link_to "次の週", root_path(date: (@selected_date + 7.days).iso8601, tab: @selected_tab), class: subtle_button_classes %>
        </div>
      </div>
      <p class="mt-3 text-xs text-stone-500">
        この週の1日平均:
        <strong class="text-sm font-semibold text-stone-800"><%= number_with_delimiter(@period_totals[:week_average]) %> kcal</strong>
      </p>
    <% end %>

    <% if @selected_tab.in?(%w[week week_average]) %>
      <article class="mt-6 <%= card_classes %>">
        <p class="<%= metric_label_classes %>">今週のタンパク質</p>

        <p class="mt-2 text-2xl font-extrabold tracking-tight text-stone-950">
          <strong><%= @protein_summary[:week_total] %> g</strong>
          <span class="mx-1 text-stone-300">/</span>
          <span class="text-lg text-stone-500"><%= @protein_summary[:week_target] %> g</span>
        </p>

        <p class="mt-2 text-sm text-stone-500">
          1日平均: <%= @protein_summary[:week_average] %> g（目標 <%= @protein_summary[:daily_target] %> g/日）
        </p>

        <p class="text-sm text-stone-500">
          <% if @protein_summary[:deficit].positive? %>
            <span>不足: <%= @protein_summary[:deficit] %> g</span>
          <% else %>
            <span>達成済み（+<%= -@protein_summary[:deficit] %> g）</span>
          <% end %>
        </p>
      </article>
    <% end %>

    <div class="mt-6 grid gap-3">
      <% @summary_rows.each do |row| %>
        <article class="<%= summary_row_classes(row[:calories]) %>">
          <div>
            <p class="font-semibold text-stone-950"><%= row[:label] %></p>
            <p class="text-sm text-stone-600"><%= row[:subtitle] %></p>
          </div>

          <div class="sm:text-right">
            <p class="text-lg font-extrabold tracking-tight"><%= number_with_delimiter(row[:calories]) %> kcal</p>

            <% if row[:protein_g] %>
              <p class="text-xs text-stone-500">タンパク質 <%= row[:protein_g] %> g</p>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <section id="input-section" class="grid gap-6 scroll-mt-28 lg:grid-cols-2">
    <% @meal_sections.each do |section| %>
      <% selected_manual_food = @daily_food_log&.food if @daily_food_log&.food&.manual_calories_enabled? %>
      <% manual_foods = section[:foods].select(&:manual_calories_enabled?) %>
      <% form_open = selected_manual_food.present? && @daily_food_log&.meal_type == section[:key] %>
      <% current_manual_food = form_open ? selected_manual_food : manual_foods.first %>
      <% current_manual_calories = form_open ? @daily_food_log.calories : nil %>

      <section id="meal-<%= section[:key] %>-section" class="<%= meal_panel_classes(section[:total_calories]) %>">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="<%= meal_badge_wrapper_classes(section[:key]) %>"><%= section[:label] %></p>
            <h2 class="mt-3 <%= section_title_classes %>"><%= section[:label] %>に食べたもの</h2>
            <p class="<%= section_description_classes %>">候補から選ぶだけで登録できます。</p>
          </div>

          <p class="text-lg font-extrabold tracking-tight text-stone-950">
            <%= number_with_delimiter(section[:total_calories]) %> kcal
          </p>
        </div>

        <div
          class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-3"
          data-controller="manual-calorie-form"
          data-manual-calorie-form-open-value="<%= form_open %>"
        >
          <% section[:foods].each do |food| %>
            <% if food.manual_calories_enabled? %>
              <button
                type="button"
                class="<%= food_button_classes %>"
                data-action="manual-calorie-form#show"
                data-manual-calorie-form-food-id-param="<%= food.id %>"
                data-manual-calorie-form-food-name-param="<%= food.name %>"
                data-manual-calorie-form-food-calories-param="<%= food.calories %>"
              >
                <%= food.name %>
              </button>
            <% else %>
              <%= button_to food.name, daily_food_logs_path(date: @selected_date.iso8601, tab: @selected_tab),
                params: { daily_food_log: { food_id: food.id, meal_type: section[:key], eaten_on: @selected_date.iso8601 } },
                class: food_button_classes %>
            <% end %>
          <% end %>

          <% if manual_foods.any? %>
            <%= form_with url: daily_food_logs_path(date: @selected_date.iso8601, tab: @selected_tab), method: :post, class: manual_calorie_form_classes, data: { action: "turbo:submit-end->manual-calorie-form#submitEnd", manual_calorie_form_target: "form" } do |form| %>
              <%= form.hidden_field :food_id, name: "daily_food_log[food_id]", value: current_manual_food&.id, data: { manual_calorie_form_target: "foodIdInput" } %>
              <%= form.hidden_field :meal_type, name: "daily_food_log[meal_type]", value: section[:key] %>
              <%= form.hidden_field :eaten_on, name: "daily_food_log[eaten_on]", value: @selected_date.iso8601 %>

              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-orange-950" data-manual-calorie-form-target="foodName">
                    <%= current_manual_food&.name %>
                  </p>

                  <p class="mt-1 text-xs leading-5 text-stone-600">カロリーを入力して登録します。</p>
                </div>

                <button
                  type="button"
                  class="text-xs font-semibold text-stone-500 transition hover:text-stone-700"
                  data-action="manual-calorie-form#hide"
                >
                  閉じる
                </button>
              </div>

              <div class="mt-3">
                <%= form.label :calories, "カロリー", class: form_label_classes %>

                <%= form.number_field :calories,
                  name: "daily_food_log[calories]",
                  min: 1,
                  step: 1,
                  value: current_manual_calories,
                  placeholder: current_manual_food&.calories.to_s,
                  class: input_classes,
                  data: { manual_calorie_form_target: "caloriesInput" } %>
              </div>

              <%= form.submit "登録する", class: "mt-3 w-full sm:w-auto #{primary_button_classes}" %>
            <% end %>
          <% end %>
        </div>

        <% if section[:logs].any? %>
          <div class="mt-5 grid gap-3">
            <% section[:logs].each do |log| %>
              <article class="<%= compact_card_classes %>">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="font-semibold text-stone-950"><%= log.food_name %></p>

                    <% if log.comment.present? %>
                      <p class="mt-1 whitespace-pre-line text-sm text-stone-600"><%= log.comment %></p>
                    <% else %>
                      <p class="text-sm text-stone-500">登録済み</p>
                    <% end %>
                  </div>

                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                    <p class="text-base font-extrabold tracking-tight text-stone-950">
                      <%= number_with_delimiter(log.calories) %> kcal
                    </p>

                    <%= button_to "削除", daily_food_log_path(log, date: @selected_date.iso8601, tab: @selected_tab), method: :delete, class: danger_button_classes, form: { data: { turbo_confirm: "この記録を削除しますか？" } } %>
                  </div>
                </div>

                <% if log.food&.manual_calories_enabled? %>
                  <details class="mt-3">
                    <summary class="cursor-pointer text-xs text-stone-500 hover:text-stone-700">
                      <%= log.comment.present? ? "コメントを編集" : "コメントを追加" %>
                    </summary>

                    <%= form_with url: daily_food_log_path(log, date: @selected_date.iso8601, tab: @selected_tab), method: :patch, class: "mt-2" do |form| %>
                      <%= form.text_area :comment, name: "daily_food_log[comment]", value: log.comment, rows: 2, placeholder: "店名や状況などのメモ", class: input_classes %>

                      <div class="mt-2">
                        <%= form.submit "保存", class: "text-xs #{primary_button_classes}" %>
                      </div>
                    <% end %>
                  </details>
                <% end %>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="<%= empty_state_classes %>">
            まだ記録がありません。上のボタンから追加してください。
          </div>
        <% end %>
      </section>
    <% end %>
  </section>

  <section id="share-section" class="<%= panel_classes %> scroll-mt-28">
    <div>
      <h2 class="<%= section_title_classes %>">AI共有用テキスト</h2>
      <p class="<%= section_description_classes %>">食事内容を自然文でコピーできます。</p>
    </div>

    <div class="mt-6 grid gap-6">
      <div data-controller="copy">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <h3 class="font-semibold text-stone-900">その日分</h3>
          <button type="button" class="<%= primary_button_classes %>" data-action="copy#copy">コピー</button>
        </div>

        <textarea
          class="<%= textarea_classes %>"
          rows="5"
          readonly
          data-copy-target="source"
        ><%= @daily_summary_text %></textarea>

        <p class="mt-3 text-sm text-stone-500" data-copy-target="status"></p>
      </div>

      <div data-controller="copy">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <h3 class="font-semibold text-stone-900">
            1週間分（<%= @selected_date.beginning_of_week.strftime("%-m/%-d") %> -
            <%= @selected_date.end_of_week.strftime("%-m/%-d") %>）
          </h3>

          <button type="button" class="<%= primary_button_classes %>" data-action="copy#copy">コピー</button>
        </div>

        <textarea
          class="<%= textarea_classes %>"
          rows="9"
          readonly
          data-copy-target="source"
        ><%= @weekly_summary_text %></textarea>

        <p class="mt-3 text-sm text-stone-500" data-copy-target="status"></p>
      </div>
    </div>
  </section>
</main>
